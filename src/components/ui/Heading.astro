---
// Heading — shared typography component for every headline across
// the site. Maps semantic `as` (h1/h2/h3/h4) to a visual `size` scale
// and a `leading` (line-height) token. Classes resolve to the exact
// inline values each call-site currently ships, so the swap produces
// zero pixel diff at any breakpoint.
//
// Scale (size prop → Tailwind classes driven by `--text-*` tokens
// defined in global.css `@theme`):
//
//   • hero         — Hero H1: 2.5 / 2.5 / 3.25rem
//   • section      — Services/WorkGrid/Testimonials H2: 2.25 / 2.75 / 3.5rem
//   • display      — Footer H2: 2.5 / 3.5 / 4.5rem
//   • card         — ServiceCard H3: 2rem (fixed)
//   • metric       — HeroMetrics number: 3rem (fixed)
//
// Leading prop → `--leading-*` tokens:
//   • display  (1.05) — footer H2
//   • tight    (1.15) — WorkGrid/Testimonials H2
//   • heading  (1.2)  — Services H2, Hero H1, card H3
//   • body     (1.4)  — button copy
//   • none     — Tailwind leading-none (metric)

const {
  as = 'h2',
  size = 'section',
  leading = 'heading',
  weight = 'black',
  class: extraClass = '',
  ...rest
} = Astro.props;

const Tag = as;

// Size → responsive font-size class string. Token classes
// (`text-h1-mobile`, etc.) are auto-generated by Tailwind 4 from the
// `--text-*` entries in `@theme`.
const sizeClasses: Record<string, string> = {
  hero: 'text-h1-mobile sm:text-h1-mobile md:text-h1-desktop',
  section: 'text-h2-mobile md:text-h2-tablet xl:text-h2-desktop',
  display: 'text-h1-mobile md:text-h2-desktop xl:text-h2-footer-desktop',
  card: 'text-h3',
  metric: 'text-metric',
};

const leadingClasses: Record<string, string> = {
  display: 'leading-display',
  tight: 'leading-heading-tight',
  heading: 'leading-heading',
  body: 'leading-body',
  none: 'leading-none',
};

const weightClasses: Record<string, string> = {
  light: 'font-light',
  normal: 'font-normal',
  medium: 'font-medium',
  bold: 'font-bold',
  black: 'font-black',
};

const classes = [
  'font-heading',
  sizeClasses[size as keyof typeof sizeClasses],
  leadingClasses[leading as keyof typeof leadingClasses],
  weightClasses[weight as keyof typeof weightClasses],
  extraClass,
]
  .filter(Boolean)
  .join(' ');
---
<Tag {...rest} class={classes}>
  <slot />
</Tag>
