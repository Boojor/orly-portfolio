---
import ServiceCard from './ServiceCard.astro';

// Content hardcoded inline — these are not config, they're content, and there are only 4.
const services = [
  {
    icon: '/assets/services/Icon_service-1.svg',
    heading: 'Turning ideas into MLP/MVP',
    description:
      'Turning early ideas into a clear direction through fast problem framing and early validation.',
    tags: [
      { label: 'Personas synthesis', color: 'mint-200' },
      { label: 'Journey mapping', color: 'blue-200' },
      { label: 'Competitive analysis', color: 'mint-100' },
    ],
  },
  {
    icon: '/assets/services/Icon_service-2.svg',
    heading: 'Plug and play design leadership',
    description:
      'Sliding into your workflow fast, absorbing context, filling gaps, and moving work forward with minimal guidance.',
    tags: [
      { label: 'User stories', color: 'yellow-300' },
      { label: 'Async collaboration', color: 'orange-200' },
      { label: 'Dev handoff & QA', color: 'yellow-600' },
    ],
  },
  {
    icon: '/assets/services/Icon_service-3.svg',
    heading: 'Visual design with purpose',
    description:
      "Creating clean, modern UI that supports your product's story and makes every screen feel intentional.",
    tags: [
      { label: 'Responsive patterns', color: 'purple-200' },
      { label: 'Component design', color: 'purple-400' },
      { label: 'Scalable typography', color: 'pink-300' },
    ],
  },
  {
    icon: '/assets/services/Icon_service-4.svg',
    // NOTE: "scales" (sic) matches the live site copy verbatim.
    heading: 'Design systems that scales',
    description:
      'Building or reorganizing a design system that reduces chaos, speeds up work, and keeps everything consistent.',
    tags: [
      { label: 'Automated design tokens', color: 'gray-200' },
      { label: 'Seamless documentation', color: 'blue-400' },
      { label: 'Component libraries', color: 'gray-400' },
    ],
  },
];
---
<section id="services" class="px-[5%] py-section-large">
  <div class="max-w-[97.5rem] mx-auto">
    <!-- Section header: label line + H2 + "See all services" secondary button -->
    <header>
      <div class="flex flex-row items-center gap-medium">
        <div class="flex flex-1 items-center gap-medium">
          <p class="whitespace-nowrap text-sm tracking-wide text-white/80">My services</p>
          <div class="h-px flex-1 bg-white/80" aria-hidden="true" />
        </div>
        {/* .button.is-secondary: inherits .button border (1px solid
            yellow-500), black bg, white text, 16px radius, 1rem 2.5rem
            padding, 1.125rem/1.4 700 weight */}
        <a
          href="#"
          class="hidden md:inline-flex items-center rounded-2xl border border-yellow-500 bg-black px-[2.5rem] py-[1rem] font-heading text-[1.125rem] leading-[1.4] font-bold text-white transition-colors hover:bg-white hover:text-black"
        >
          See all services
        </a>
      </div>

      <div class="h-medium" aria-hidden="true" />

      <h2 class="font-heading text-[2.25rem] md:text-[2.75rem] xl:text-[3.5rem] leading-[1.2] font-black">
        What I do best
      </h2>
    </header>

    <!-- spacer-large -->
    <div class="h-large" aria-hidden="true" />

    {/* Mobile: horizontal scroll-snap carousel (matches live's Swiper).
        Tablet+: 2-col grid. Desktop lg+: 4-col grid. Full Swiper animation
        deferred to Phase 4. */}
    {/* Gap is `gap-small` (1.5rem = 24px) to match live Webflow's layout:
        live uses `.services-slider_cms_item { padding: 0 .75rem }` which
        gives an effective 24px between adjacent cards. Previously we
        used `gap-large` (48px) which made cards visibly thinner — local
        306→288px at 1440 per scripts/services-card-diff.mjs. */}
    <div
      data-carousel="services"
      class="flex snap-x snap-mandatory gap-small overflow-x-auto pb-small [scrollbar-width:none] [&::-webkit-scrollbar]:hidden md:grid md:snap-none md:grid-cols-2 md:overflow-visible md:pb-0 lg:grid-cols-4"
    >
      {services.map((svc) => (
        <div data-carousel-slide class="shrink-0 basis-full snap-start md:basis-auto md:shrink">
          <ServiceCard
            icon={svc.icon}
            heading={svc.heading}
            description={svc.description}
            tags={svc.tags}
          />
        </div>
      ))}
    </div>

    {/* Pagination dots — matches live Swiper's bullet output at every
        breakpoint. Swiper uses slidesPerView:"auto" and the slide width
        changes by media query, so the visible bullet count is:
          - <768 (100% slide width): 4 dots
          - 768-991 (50% slide width): 3 dots (4 − 2 + 1)
          - ≥992 (25% slide width, all visible): 1 dot (swiper-pagination-lock)
        Dot size also switches at 992: 0.625rem → 1rem. Render all 4 dots
        in markup and hide the extras per BP via @layer utilities rules
        keyed on [data-dot-index] (see global.css). Plain CSS — Tailwind's
        `lg:` is 1024 and would drift the 992-1023 window. */}
    <div
      data-carousel-dots="services"
      class="mt-medium flex items-center justify-center gap-[0.5rem]"
    >
      {[0, 1, 2, 3].map((i) => (
        <button
          type="button"
          data-carousel-dot={i}
          data-dot-index={i}
          aria-label={`Go to slide ${i + 1}`}
          class:list={[
            'inline-block aspect-square rounded-full border border-yellow-500 w-[0.625rem] p-0 cursor-pointer transition-colors',
            i === 0 ? 'bg-yellow-500' : 'bg-transparent',
          ]}
        />
      ))}
    </div>

    {/* Mobile-only bottom "See all services" button — ports live's
        `<div class="show-mobile-landscape"><div class="button-group is-center">`
        which renders the button centered below the carousel at ≤767px.
        Live CSS: button-group is-center → justify-content: center. */}
    <div class="mt-large flex justify-center md:hidden">
      <a
        href="#"
        class="inline-flex items-center justify-center rounded-2xl border border-yellow-500 bg-black px-[2.5rem] py-[1rem] font-heading text-[1.125rem] leading-[1.4] font-bold text-white transition-colors hover:bg-white hover:text-black"
      >
        See all services
      </a>
    </div>
  </div>
</section>
