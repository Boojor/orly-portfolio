---
import HeroSplitText from './HeroSplitText.astro';
import HeroMetrics from './HeroMetrics.astro';
import VerticalLabel from './VerticalLabel.astro';
import ScrollNavSwapper from '../layout/ScrollNavSwapper.astro';

// Headline structure mirrors the live Webflow markup — four decorated
// "figure", "it", "out", "later" words flow inside the larger sentence.
// "I turn" is split into two tokens so per-word animation stays clean.
const headlineWords = [
  'I',
  'turn',
  'figure',
  'it',
  'out',
  'later',
  'into',
  'shipped',
  'product',
];
const highlightIndex = [2, 3, 4, 5];
const marks: (string | null)[] = [
  null,
  null,
  '/assets/hero/mark-figure.svg',
  '/assets/hero/mark-it.svg',
  '/assets/hero/mark-out.svg',
  null,
  null,
  null,
  null,
];

const subcopy =
  "I dig into the business mess, figure out what actually drives value, and design experiences that deliver. Less stakeholder theater, more product in users' hands.";

const metrics = [
  { value: '15+ yrs', label: 'Shaping Products' },
  { value: '170+', label: 'Products & Features Shipped' },
  { value: '93%', label: 'Clients Returning for More' },
];
---
<section class="relative overflow-hidden">
  <ScrollNavSwapper />

  {/* Background image is rendered at body level in BaseLayout.astro
     (matches live .bg-image which is a sibling of main-wrapper).
     No overlay — the source image's dark left side carries the
     headline's text contrast. */}

  {/* Hero fills the full viewport width (minus 5% padding). At
      ultra-wide viewports (>1560px) the 97.5rem container cap live
      uses creates an awkward empty gap on the right where the
      portrait and metrics don't reach. Dropping the cap lets the
      3 grid columns spread equally across the full content width
      at all breakpoints, which looks better at wide screens and
      identical at <=1560px viewports.

      Desktop=992+ padding-top override lives in global.css under
      @layer utilities (data-hero-padding). */}
  <div class="px-[5%]">
  <div data-hero-padding class="relative w-full pt-[8rem] pb-[20px]">
    {/* .hero_layout: base 3 equal columns with 1rem gap, tablet drops
        to 2 cols (metrics hidden), mobile collapses to 1 col. The
        `desktop=992+` rule lives in global.css under @layer utilities
        (data-hero-layout) — see comments there for why arbitrary
        Tailwind breakpoints don't work for this. */}
    <div data-hero-layout class="grid grid-cols-1 gap-4 md:grid-cols-2 items-stretch">
      {/* Column 1 — headline + sub + CTA. Live .hero_heading-wrapper
          uses 1.5rem gap between children. */}
      <div data-hero-col="1" class="flex flex-col items-start gap-[1.5rem]">
        <HeroSplitText
          words={headlineWords}
          highlightIndex={highlightIndex}
          marks={marks}
        />

        {/* Live's hero subcopy <p> uses global p styles (no class):
            font-size: 1rem (16px), line-height: 1.4 (22.4px).
            Previously text-lg/md:text-xl + leading-relaxed made the
            paragraph 25% larger + 16% looser, which wrapped more
            lines and blew up the column by ~84px. Literal port. */}
        <p class="font-body text-base leading-[1.4] text-stone-200">
          {subcopy}
        </p>

        <div>
          {/* .button base from live: bg-yellow-500, white text, 16px radius,
              1rem 2.5rem padding, 1.125rem 700 weight */}
          <a
            href="#contact"
            class="inline-flex items-center justify-center rounded-2xl border border-yellow-500 bg-yellow-500 px-[2.5rem] py-[1rem] font-heading text-[1.125rem] leading-[1.4] font-bold text-white transition-colors hover:bg-yellow-600 hover:border-yellow-600"
          >
            Book a consult
          </a>
        </div>
      </div>

      {/* Column 2 — portrait. Live .hero_visual: width 100%,
          min-height 31.25rem (500px), position relative. .image-hero:
          absolute fill, object-contain. */}
      <div data-hero-col="2" class="relative w-full min-h-[31.25rem]">
        <img
          src="/assets/hero/portrait.webp"
          alt="Portrait of Orly Boojor"
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 h-full w-full object-contain"
        />
      </div>

      {/* Column 3 — metrics stack + vertical label. Hidden below 992
         to match live's `.hero_metrics-wrapper { display: none }` at
         max-width: 991px. Visibility controlled by data-hero-metrics-col
         in global.css @layer utilities. */}
      {/* Col 3 children: metrics stack on the left, vertical label
          pinned to the right edge of the column. justify-between +
          no gap → label touches col3's right edge (matches live
          where .vertical-label--hero sits at col3.right=1368). */}
      <div data-hero-metrics-col class="hidden items-stretch justify-between">
        <HeroMetrics metrics={metrics} />
        <VerticalLabel />
      </div>

      {/* Mobile metrics (shown only on smallest screens, matching the
         live site which drops metrics on tablet via `display: none`). */}
      <div class="md:hidden">
        <HeroMetrics metrics={metrics} />
      </div>
    </div>
  </div>
  </div>
</section>
