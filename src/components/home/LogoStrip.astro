---
// Static partner logo grid. Marquee animation deferred to a later polish pass.
const logos = [
  { src: '/assets/logos/Partner-logos.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-1.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-2.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-3.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-4.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-5.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-6.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-7.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-9.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-10.svg', alt: 'Partner' },
  { src: '/assets/logos/Partner-logos-11.svg', alt: 'Partner' },
];
---
{/* Logo strip: edge-to-edge, no container cap. Logos are rendered
    TWICE so they visually fill the viewport at wide widths (the
    second set flows off-screen and will be used as the seamless
    wrap-around for the Phase 4 marquee animation). overflow-hidden
    clips cleanly at the viewport edges so no logo looks cut off. */}
<section
  id="logos"
  class="pt-[1.5rem] pb-[1rem] overflow-hidden"
>
  <ul
    class="flex flex-nowrap items-center gap-xlarge md:gap-xxlarge w-max"
  >
    {[...logos, ...logos].map((logo) => (
      <li class="flex shrink-0 items-center justify-center">
        <img
          src={logo.src}
          alt={logo.alt}
          class="max-h-10 md:max-h-14 w-auto opacity-80 hover:opacity-100 transition-opacity"
          loading="lazy"
        />
      </li>
    ))}
  </ul>
</section>
