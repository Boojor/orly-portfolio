---
// Case study page — literal port of
// orly-website.webflow/my-work/untitled-extending-fundbox-through-strategic-partnerships.html
// Deployed: https://orly-website.webflow.io/my-work/untitled-extending-fundbox-through-strategic-partnerships
// Local route: /my-work/fundbox-partnerships (clean slug; matches config.ts + OtherProjects).
//
// Body is light themed (.white-body), nav uses light variant — same as the
// other two case-study pages.
//
// Built in 4 batches (see plan at ~/.claude/plans/great-now-review-the-sparkling-cake.md):
//   Batch 1 (this commit): assets + shared sections 1-4 + 9 + placeholder
//                          <header>s for sections 5-8.
//   Batch 2: work_problem_section with fundux_problem_component (UX Archaeology).
//   Batch 3: 3x work_in-context_section (eBay / Synchrony / Stripe partner cases).
//   Batch 4: polish + heatmap sweep at all 5 BPs.
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/layout/Nav.astro';
import MobileNav from '../../components/layout/MobileNav.astro';
import Footer from '../../components/layout/Footer.astro';
import ScrollNavSwapper from '../../components/layout/ScrollNavSwapper.astro';
import Testimonials from '../../components/home/Testimonials.astro';
import OtherProjects from '../../components/work/OtherProjects.astro';

const ASSETS = '/assets/work/fundbox-partnerships';
// Shared Webflow icons live under /assets/work/cinch (first case study that
// imported them). Mobile-phone.svg, footer.svg, NAVBARLOGO.svg etc. are
// served via the Nav/Footer components directly and don't need re-import.
const CINCH_ASSETS = '/assets/work/cinch';
---

<BaseLayout
  title="Extending Fundbox Through Strategic Partnerships"
  bodyClass="white-body"
  showHeroBg={false}
>
  <Nav slot="nav" variant="light" />
  <MobileNav />

  <main>
    {/* 1. work_hero_section — "Jump to" dropdown + full-bleed PARTNER_1.png
         bg. Live: .image-cover.contain.bottom pins the hero photo to the
         bottom of the frame (unlike cinch which uses plain .image-cover).
         ratio90-49 forces a 90:49 aspect on the bg wrapper. */}
    <ScrollNavSwapper />
    <header class="work_hero_section is-fundbox" data-partnerships-section="hero">
      <div class="padding-global">
        <div class="container-large">
          <div class="hero-content">
            <div class="work_dropdown">
              <div class="dropdown">
                <img src={`${CINCH_ASSETS}/2222.svg`} loading="lazy" alt="" class="icon-1x1-small" />
                <div class="text-size-small">Jump to</div>
                <img src={`${CINCH_ASSETS}/Arrow-Dot-Down-1-Streamline-Streamline-Regular-3.0.svg`} loading="lazy" alt="" class="icon-1x1-small" />
                <img src={`${CINCH_ASSETS}/Arrow-Thick-Down-4-Streamline-Streamline-Regular-3.0.svg`} loading="lazy" alt="" class="icon-1x1-small" />
              </div>
              <div class="dropdown-text">
                <div class="dropdown-padding">
                  {/* Option 1-4 are placeholder labels in live source — port literally per CLAUDE.md rule.
                      TODO(content): real jump-to targets once anchors are wired. */}
                  <a href="#" class="section_link">Option 1</a>
                  <div class="line-fill"></div>
                  <a href="#" class="section_link">Option 2</a>
                  <div class="line-fill"></div>
                  <a href="#" class="section_link">Option 3</a>
                  <div class="line-fill"></div>
                  <a href="#" class="section_link">Option 4</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="background-image-wrapper ratio90-49">
        <img loading="eager" src={`${ASSETS}/PARTNER_1.png`} alt="" class="image-cover contain bottom" />
      </div>
    </header>

    {/* 2. work_case-intro_section — H1 + subtitle + meta list + tag pills.
         Copy lifted verbatim from the live export. */}
    <header class="work_case-intro_section" data-partnerships-section="case-intro">
      <div class="padding-global">
        <div class="container-large">
          <div class="padding-section-large work">
            <div class="max-width-xlarge">
              <h1 class="heading-style-h1">Extending Fundbox Through Strategic Partnerships</h1>
              <div class="spacer-xxsmall"></div>
              <p class="heading-style-h4">Designed Fundbox to feel native inside other products - often in under a week.</p>
            </div>
            <div class="spacer-large"></div>
            <div class="divider-horizontal"></div>
            <div class="spacer-large"></div>
            <div class="case_meta">
              <div class="case_meta-list">
                <div class="meta-text">
                  <p class="text-weight-bold">Product Context</p>
                  <p>Web &amp; Mobile apps</p>
                </div>
                <div class="meta-text">
                  <p class="text-weight-bold">End Users</p>
                  <p>Partner executives evaluating Fundbox integration</p>
                </div>
                <div class="meta-text">
                  <p class="text-weight-bold">Project Duration</p>
                  <p>1-2 weeks</p>
                </div>
                <div class="meta-text">
                  <p class="text-weight-bold">Industry</p>
                  <p>Fintech  ·  B2B Payments  ·  Strategic Partnerships</p>
                </div>
              </div>
              <div class="case_tags">
                <div class="tag"><div class="text-truncate">UX strategy</div></div>
                <div class="tag"><div class="text-truncate">Persona definition</div></div>
                <div class="tag"><div class="text-truncate">Information Architecture</div></div>
                <div class="tag"><div class="text-truncate">Journey mapping</div></div>
                <div class="tag"><div class="text-truncate">Visual design</div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    {/* 3. work_outcome_section — Pic_1.webp featured image. */}
    <header class="work_outcome_section" data-partnerships-section="outcome">
      <div class="padding-global">
        <div class="container-large">
          <div class="padding-section-small">
            <div class="case_media">
              <img src={`${ASSETS}/Pic_1.webp`} loading="lazy" alt="" class="outcome-product" />
            </div>
          </div>
        </div>
      </div>
    </header>

    {/* 4. work_context_section — "What is Fundbox Partnerships?" narrative. */}
    <header class="work_context_section" data-partnerships-section="context">
      <div class="padding-global">
        <div class="container-large">
          <div class="padding-section-large">
            <div class="context_component">
              <div class="case_component-info">
                <h2 class="heading-style-h2 project-page">What is Fundbox Partnerships?</h2>
                <div class="spacer-xsmall"></div>
                <div class="p-wrapper">
                  <p>Fundbox helps small businesses access credit. <br />As Fundbox matured, growth shifted from direct acquisition to strategic partnerships, embedding credit capabilities inside platforms customers already trusted. eBay, Stripe, Synchrony. <br /></p>
                  <p>These weren&rsquo;t marketing integrations. They were product extensions. I was Lead Designer for partnership concepts, owning UX strategy, flow design, and high-fidelity prototypes alongside Sales, Product, and Engineering.</p>
                </div>
              </div>
              <p class="heading-style-h4"><span class="text-weight-semibold">How to make a mature fintech product feel native inside someone else&rsquo;s ecosystem</span> with 48-72 hour turnarounds. The prototypes I created were used in executive pitch meetings, aligned internal teams around a shared vision, and directly informed the UX patterns we shipped in Fundbox Pay Checkout.</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    {/* 5. work_problem_section — "My Approach: UX Archaeology".
         Dark gray bg (is-color-gray800), white text. Left column:
         illustration_1.svg diagram. Right column: heading + intro + bullet
         questions + closing paragraph. blur_3.webp positioned absolutely
         bottom-right behind content for depth. */}
    <header class="work_problem_section text-color-white is-color-gray800" data-partnerships-section="problem">
      <div class="padding-global">
        <div class="container-large">
          <div class="padding-section-large">
            <div class="fundux_problem_component vertical">
              <img src={`${ASSETS}/illustration_1.svg`} loading="lazy" alt="" class="problem_diagram" />
              <div class="max-width-small">
                <h2 class="heading-style-h2 project-page">My Approach: UX Archaeology</h2>
                <div class="spacer-xsmall"></div>
                <p>To fill the research gap, I developed what I came to call &ldquo;UX Archaeology&rdquo; reverse-engineering the partner&rsquo;s existing UI patterns.</p>
                <div class="spacer-xsmall"></div>
                <div class="w-richtext">
                  <p>The questions I ask:</p>
                  <ul role="list">
                    <li>What does this platform&rsquo;s current flow assume about user context and attention?</li>
                    <li>Where does the partner already own the trust relationship?</li>
                    <li>What interaction patterns do their users take for granted?</li>
                  </ul>
                  <p>From there, I&rsquo;d deconstruct Fundbox&rsquo;s product into its core decision moments and rebuild the experience to match the partner&rsquo;s existing narrative.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <img src={`${ASSETS}/blur_3.webp`} loading="lazy" alt="" class="problem_image-blur-dark" />
    </header>

    {/* 6. work_in-context_section (eBay) — "Financing as Commerce Behavior".
         Text block + full-width ebay_pic.png with black quote panel below. */}
    <header class="work_in-context_section overflow-hidden" data-partnerships-section="in-context-ebay">
      <div class="padding-global">
        <div class="container-large">
          <div id="padding" class="padding-section-huge">
            <div class="in-context_layout">
              <div class="in-context_label">
                <div class="in-context-heading-wrapper">
                  <h2 class="heading-style-h4">Financing as Commerce Behavior</h2>
                  <img src={`${ASSETS}/Vector_1.svg`} loading="lazy" alt="" />
                </div>
                <div class="in-context_text">
                  <div class="in-context_paragraph">
                    <p class="text-weight-semibold">Context</p>
                    <div class="spacer-xsmall"></div>
                    <p>eBay&rsquo;s Seller Hub is an information-dense environment. Sellers are simultaneously managing inventory, shipping, feedback, and cash flow. Attention is fragmented. Tolerance for disruption is low.</p>
                  </div>
                  <div class="in-context_paragraph">
                    <p class="text-weight-semibold">The Decision: In-Context CTAs Over Popups</p>
                    <div class="spacer-xsmall"></div>
                    <div class="p-wrapper">
                      <p class="p-wrapper-text">I integrated Fundbox as a native peer-level tab (&quot;Capital&quot; sitting alongside existing navigation). More importantly, I placed financing CTAs directly in context: on high-value listing pages, next to inventory that sellers might want to finance.<br /></p>
                      <p class="p-wrapper-text">The goal was to make credit feel like a standard commerce behavior, closer to &quot;Add to Cart&quot; than &quot;Apply for a Loan.&quot;</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="ebay_case">
        <img src={`${ASSETS}/ebay_pic.png`} loading="lazy" alt="" class="ebay_image" />
        <div class="ebay_quote_wrapper">
          <div class="padding-global">
            <div class="padding-section-small">
              <div class="container-large">
                <div class="ebay_quote">
                  <div class="line"></div>
                  <div class="ebay_quote-content">
                    <div class="max-width-large">
                      <p class="heading-style-h4">&ldquo;I&rsquo;ve got a truck half-loaded and a customer waiting. I need to know if I can buy this lumber, not read a contract.&rdquo;</p>
                    </div>
                    <div class="spacer-xsmall"></div>
                    <p><span class="text-weight-semibold">Mike Reyes,</span> General Contractor</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    {/* 7. work_in-context_section (Synchrony) — "Mobile-First for the Field".
         Text block + 2-part image composition: top (pc_mockup + mobiles)
         and bottom (banner with overlay quote). */}
    <header class="work_in-context_section overflow-hidden" data-partnerships-section="in-context-synchrony">
      <div class="padding-global">
        <div class="container-large">
          <div id="padding" class="padding-section-large">
            <div class="in-context_layout">
              <div class="in-context_label">
                <div class="in-context-heading-wrapper">
                  <h2 class="heading-style-h4">Mobile-First for the Field</h2>
                  <img src={`${ASSETS}/Frame-1000002292.svg`} loading="lazy" alt="" />
                </div>
                <div class="in-context_text">
                  <div class="in-context_paragraph">
                    <p class="text-weight-semibold">Context</p>
                    <div class="spacer-xsmall"></div>
                    <p>Synchrony&rsquo;s, a potential partner in the credit industry, users looked nothing like eBay&rsquo;s. Think of a contractor at a lumber yard, phone in hand, needing to verify purchasing power before loading materials into a truck. Desktop-heavy flows wouldn&rsquo;t survive this context.</p>
                  </div>
                  <div class="in-context_paragraph">
                    <p class="text-weight-semibold">The Decision: In-Context CTAs Over Popups</p>
                    <div class="spacer-xsmall"></div>
                    <div class="p-wrapper">
                      <p class="p-wrapper-text">Every screen had one job. No branching, no optional steps. The breakthrough was address verification. Traditional KYC requires typing a full address, painful on mobile. I replaced this with an interactive map: tap to confirm location, done.<br /></p>
                      <p class="p-wrapper-text">Once approved, users saw a digital card visualization, their purchasing power rendered as something tangible for the register.</p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="synchrony_case">
                <div class="synchrony_case_top">
                  <img src={`${ASSETS}/pc_mockup.png`} loading="lazy" alt="" class="synchrony_image" />
                  <img src={`${ASSETS}/mobiles_synchrony.png`} loading="lazy" alt="" class="image-2123125" />
                </div>
                <div class="synchrony_case_bottom">
                  <div class="synchrony-overlay"></div>
                  <img src={`${ASSETS}/banner.png`} loading="lazy" alt="" class="synchrony_image" />
                  <div class="synchrony_case_quote">
                    <div class="work_user-testing_quote">
                      <div class="sync_quote">
                        <div class="max-width-large">
                          <p class="heading-style-h4 text-align-left">&ldquo;I&rsquo;ve got a truck half-loaded and a customer waiting. I need to know if I can buy this lumber, not read a contract.&rdquo;</p>
                        </div>
                        <div class="spacer-xsmall"></div>
                        <p><span class="text-weight-semibold">Mike Reyes,</span> General Contractor</p>
                      </div>
                      <div class="line"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    {/* 8. work_in-context_section (Stripe) — "Invisible Finance for Power Users".
         Text block + 6-tile grid (reuses .grid-images from fundbox-pay-checkout).
         Webflow exposes each image as a lightbox link; we keep the DOM anchors
         but the lightbox JS is deferred (placeholders stay as href="#"). */}
    <header class="work_in-context_section" data-partnerships-section="in-context-stripe">
      <div class="padding-global">
        <div class="container-large">
          <div id="padding" class="padding-section-large">
            <div class="in-context_layout">
              <div class="in-context_label">
                <div class="in-context-heading-wrapper">
                  <h2 class="heading-style-h4">Invisible Finance for Power Users</h2>
                  <img src={`${ASSETS}/Vector.svg`} loading="lazy" alt="" />
                </div>
                <div class="in-context_text">
                  <div class="in-context_paragraph">
                    <p class="text-weight-semibold">Context</p>
                    <div class="spacer-xsmall"></div>
                    <p>Stripe&rsquo;s brand identity is built on developer-centric, minimalist efficiency. Their users are sophisticated, comfortable with APIs, dashboards, and financial complexity. They don&rsquo;t need hand-holding. They need control.</p>
                  </div>
                  <div class="in-context_paragraph">
                    <p class="text-weight-semibold">The Decision: In-Context CTAs Over Popups</p>
                    <div class="spacer-xsmall"></div>
                    <div class="p-wrapper">
                      <p class="p-wrapper-text">Stripe users think in cash flow, not fixed bills. A rigid weekly payment would feel like a constraint, not a tool. I designed a slider tying repayment to a percentage of daily payouts. Instead of &quot;Pay $500 every Tuesday,&quot; users saw &quot;Repay 10% of daily revenue.&quot; The financing breathed with the business.<br /></p>
                      <p class="p-wrapper-text">Fundbox transactions appeared directly in Stripe&rsquo;s existing ledger. No separate section, no context switch. Just another cash-flow event.</p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="grid-images">
                <a href="#" class="grid-images-1-25 is-padding-0 shadow-small">
                  <img src={`${ASSETS}/Frame-1000002341.png`} loading="lazy" alt="" class="image-cover contain" />
                </a>
                <div class="grid-images-3 hide-mobile-landscape">
                  <img src={`${ASSETS}/7610fa2b356eccb728e13973b6837e5275bcc5b1.webp`} loading="lazy" alt="" class="image-cover is-black-image" />
                </div>
                <a href="#" class="grid-images-4 is-padding0">
                  <img src={`${ASSETS}/Item.png`} loading="lazy" alt="" class="image-cover mobile-contain" />
                </a>
                <div class="grid-images-4 is-padding0">
                  <img src={`${ASSETS}/Item2.png`} loading="lazy" alt="" class="image-cover contain" />
                </div>
                <div class="grid-images-3 hide-mobile-landscape">
                  <img src={`${ASSETS}/3f8767b2479b90e83ccb921a835e457f1d6d5c24-compressed.jpg`} loading="lazy" alt="" class="image-cover is-black-image" />
                </div>
                <a href="#" class="grid-images-1-25 is-padding-0 shadow-small">
                  <img src={`${ASSETS}/1935e6474c95ba3d187db64ce54d68ba26405e3a-compressed.jpg`} loading="lazy" alt="" class="image-cover mobile-contain" />
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    {/* 9 + 10. Testimonials + OtherProjects — wrapped in a shared
         gray-800 container matching live's
         .work_testimonials_section.text-color-white.is-bg-gray800
         (orly-website.webflow.css:2082). Both blocks render against
         one unified dark background, so <Testimonials bgVariant="none">
         and OtherProjects bgColor="transparent" let the wrapper show
         through. Same pattern as Pay Checkout's blue-gradient wrapper. */}
    <div class="work_testimonials_section text-color-white is-bg-gray800">
      <Testimonials bgVariant="none" />
      <OtherProjects currentSlug="fundbox-partnerships" bgColor="transparent" />
    </div>
  </main>

  <Footer slot="footer" variant="dark" />
</BaseLayout>

{/* Jump-to dropdown — hover-to-open, hover-out to close (per QA).
    Hover fires on the whole wrapper so moving from the trigger pill
    down into the menu pane keeps it open. Touch devices get a click
    fallback since hover isn't reliable there.
    Identical behavior to cinch-logistics.astro. */}
<script>
  const dropdowns = document.querySelectorAll<HTMLElement>('.work_dropdown');
  dropdowns.forEach((wrap) => {
    const pane = wrap.querySelector<HTMLElement>('.dropdown-text');
    const trigger = wrap.querySelector<HTMLElement>('.dropdown');
    if (!pane || !trigger) return;
    wrap.addEventListener('mouseenter', () => pane.classList.add('is-open'));
    wrap.addEventListener('mouseleave', () => pane.classList.remove('is-open'));
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      pane.classList.toggle('is-open');
    });
  });
</script>
