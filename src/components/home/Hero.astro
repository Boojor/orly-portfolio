---
import HeroMetrics from './HeroMetrics.astro';
import VerticalLabel from './VerticalLabel.astro';
import ScrollNavSwapper from '../layout/ScrollNavSwapper.astro';
import Button from '../ui/Button.astro';
import Heading from '../ui/Heading.astro';

// Headline mirrors live Webflow's `.hero_heading-text` structure literally:
//
//   I turn  <span class="first">figure</span> <span class="second">it</span>
//   <span class="third">out</span> <span class="is-color">later </span>into
//   shipped product
//
// Key property: "I turn" and "into shipped product" are plain text nodes
// directly under the <h1>, not per-word spans. Each decorated word is a
// single <span> with a background-image mark; "later" is highlighted
// yellow (`is-color`). This keeps the sentence DOM-readable as one phrase.
// See section-audit.mjs: prior per-word split fragmented the own-text into
// "turn/into/shipped/product" and failed parity.

const subcopy =
  "I dig into the business mess, figure out what actually drives value, and design experiences that deliver. Less stakeholder theater, more product in users' hands.";

const metrics = [
  { value: '15+ yrs', label: 'Shaping Products' },
  { value: '170+', label: 'Products & Features Shipped' },
  { value: '93%', label: 'Clients Returning for More' },
];
---
<section class="relative overflow-hidden">
  <ScrollNavSwapper />

  {/* Background image is rendered at body level in BaseLayout.astro
     (matches live .bg-image which is a sibling of main-wrapper).
     No overlay — the source image's dark left side carries the
     headline's text contrast. */}

  {/* Live nesting: .padding-global { padding: 0 5% } wraps
      .container-large { max-width: 97.5rem; margin: 0 auto }.
      Below 1560px viewport: content fills 90% of viewport (5% gutters).
      At ≥1560px: content capped at 1560px, centered, with remaining
      space as gutters. Literal port of live.

      Desktop=992+ padding-top override lives in global.css under
      @layer utilities (data-hero-padding). */}
  <div class="px-[5%]">
  <div data-hero-padding class="relative mx-auto w-full max-w-[97.5rem] pt-[8rem] pb-[20px]">
    {/* .hero_layout: base 3 equal columns with 1rem gap, tablet drops
        to 2 cols (metrics hidden), mobile collapses to 1 col. The
        `desktop=992+` rule lives in global.css under @layer utilities
        (data-hero-layout) — see comments there for why arbitrary
        Tailwind breakpoints don't work for this. */}
    <div data-hero-layout class="grid grid-cols-1 gap-4 md:grid-cols-2 items-stretch">
      {/* Column 1 — headline + sub + CTA. Live .hero_heading-wrapper
          uses 1.5rem gap between children. */}
      <div data-hero-col="1" class="order-2 md:order-none flex flex-col items-start gap-[1.5rem]">
        {/* Literal port of live .hero_heading-text markup: text nodes
            flow through the sentence, decorated words are inline spans.
            Font-size and line-height match live; desktop override lives
            in global.css (@layer utilities, [data-hero-headline]). */}
        <Heading
          as="h1"
          size="hero"
          leading="heading"
          weight="light"
          data-hero-headline
          class="text-white"
        >
          I turn{' '}
          <span class="hero-mark" style="--hero-mark-img: url('/assets/hero/mark-figure.svg');">figure</span>{' '}
          <span class="hero-mark" style="--hero-mark-img: url('/assets/hero/mark-it.svg');">it</span>{' '}
          <span class="hero-mark" style="--hero-mark-img: url('/assets/hero/mark-out.svg');">out</span>{' '}
          <span class="text-yellow-500">later </span>into shipped product
        </Heading>

        {/* Live's hero subcopy <p> uses global p styles (no class):
            font-size: 1rem (16px), line-height: 1.4 (22.4px).
            Previously text-lg/md:text-xl + leading-relaxed made the
            paragraph 25% larger + 16% looser, which wrapped more
            lines and blew up the column by ~84px. Literal port. */}
        <p class="font-body text-base leading-[1.4] text-stone-200">
          {subcopy}
        </p>

        <div>
          <Button variant="primary" href="#contact">Book a consult</Button>
        </div>
      </div>

      {/* Column 2 — portrait. Live .hero_visual: width 100%,
          min-height 31.25rem (500px), position relative. .image-hero:
          absolute fill, object-contain. */}
      {/* Mobile (≤767px): portrait is relative-positioned (natural
          size). Tablet+: absolute-fill inside a 500px min-height
          container. Matches live: .hero_visual { min-height: auto }
          and .image-hero { position: relative } at ≤767px. */}
      <div data-hero-col="2" class="order-1 md:order-none relative w-full md:min-h-[31.25rem] mb-[1rem] md:mb-0">
        <img
          src="/assets/hero/Photo.webp"
          alt="Portrait of Orly Boojor"
          loading="eager"
          fetchpriority="high"
          class="relative md:absolute md:inset-0 h-auto md:h-full w-full object-contain"
        />
      </div>

      {/* Column 3 — metrics stack + vertical label. Hidden below 992
         to match live's `.hero_metrics-wrapper { display: none }` at
         max-width: 991px. Visibility controlled by data-hero-metrics-col
         in global.css @layer utilities. */}
      {/* Literal port of live .hero_metrics-wrapper:
          flex-row, items-center (vertical center), justify-end
          (right-align), gap 3.5rem. Children: metrics stack on
          left, vertical label on right. Col height is stretched
          (by grid items-stretch) so items-center centers content
          vertically within the hero's full height. */}
      <div data-hero-metrics-col class="hidden items-center justify-end gap-[3.5rem]">
        <HeroMetrics metrics={metrics} />
        <VerticalLabel />
      </div>

      {/* Note: live hides .hero_metrics-wrapper entirely at ≤991px
          (tablet + mobile). KPIs only appear at desktop (992+) via
          [data-hero-metrics-col] in global.css @layer utilities. */}
    </div>
  </div>
  </div>
</section>
