---
// Testimonials section — mirrors `.work_testimonials_section` on live Webflow.
// Live uses a Swiper slider (2 slides × 2 cards); we render slide 1 statically
// (2 cards) with non-functional prev/next arrows for visual parity. Swiper
// animation is deferred to Phase 4.
//
// Quotes, names, roles, and avatars are copied LITERALLY from the live site —
// including the CMS-flattened duplicate wording and the fact that all four
// cards use the same person and same Avatar-898.svg placeholder.

interface Testimonial {
  quote: string;
  name: string;
  role: string;
}

const slide1: Testimonial[] = [
  {
    quote:
      '“Hiring Orly was one of our best product decisions. She has a unique talent for translating high-level business goals into a user experience that just works.“Hiring Orly was one of our best product decisions. She has a unique talent for translating high-level business goals into a user.”',
    name: 'Sarah Jenkins',
    role: 'CEO, Kestrel',
  },
  {
    quote:
      '“Hiring Orly was one of our best product decisions. She has a unique talent for translating high-level business goals into a userthat just.”',
    name: 'Sarah Jenkins',
    role: 'CEO, Kestrel',
  },
];

const avatar = '/assets/testimonials/Avatar-898.svg';
const bgSrc = '/assets/testimonials/footer-image.webp';
const bgSrcset = [
  '/assets/testimonials/footer-image-p-500.webp 500w',
  '/assets/testimonials/footer-image-p-800.webp 800w',
  '/assets/testimonials/footer-image-p-1080.webp 1080w',
  '/assets/testimonials/footer-image-p-1600.webp 1600w',
  '/assets/testimonials/footer-image-p-2000.webp 2000w',
  '/assets/testimonials/footer-image.webp 4312w',
].join(', ');
---
<section id="testimonials" class="relative isolate overflow-hidden">
  {/* Full-bleed background image — live uses min-height:1400px so the
      image dominates the section. We let it fill + apply a gentle dark
      gradient for text legibility without hiding the image. */}
  <img
    src={bgSrc}
    srcset={bgSrcset}
    sizes="100vw"
    alt=""
    loading="lazy"
    class="absolute inset-0 z-0 h-full w-full object-cover"
  />
  <div
    class="absolute inset-0 z-[1] bg-gradient-to-b from-bg/70 via-bg/40 to-bg/70"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 px-small md:px-large py-section-large">
    <div class="mx-auto max-w-site-xlarge">
      {/* Header: label + heading + arrows (arrows deferred to Phase 4) */}
      <div class="flex flex-col gap-medium">
        {/* Label row */}
        <div class="flex items-center gap-small">
          <p class="font-body text-xs uppercase tracking-widest text-stone-200">
            Testimonials
          </p>
          <div class="h-px flex-1 bg-white/30" aria-hidden="true"></div>
        </div>

        {/* Heading + arrows */}
        <div class="flex flex-col gap-medium md:flex-row md:items-end md:justify-between md:gap-large">
          <h2
            class="font-heading text-[2.25rem] md:text-[2.75rem] xl:text-[3.5rem] leading-[1.15] font-black text-white max-w-site-large"
          >
            What my team has to say
          </h2>

          {/* Prev/Next buttons — visual parity only (non-functional; swiper deferred) */}
          <div class="flex gap-small" aria-hidden="true">
            <button
              type="button"
              disabled
              class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-transparent bg-white/10 text-white transition-opacity disabled:opacity-50"
              aria-label="Previous testimonial (disabled)"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                class="rotate-180"
              >
                <path
                  d="M0.8125 8H15.1875"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
                <path
                  d="M8.47949 14.7087L15.1878 8.00033L8.47949 1.29199"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </button>
            <button
              type="button"
              disabled
              class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-transparent bg-white/10 text-white transition-opacity disabled:opacity-50"
              aria-label="Next testimonial (disabled)"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
              >
                <path
                  d="M0.8125 8H15.1875"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
                <path
                  d="M8.47949 14.7087L15.1878 8.00033L8.47949 1.29199"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      {/* Slide 1: 2 cards stacked vertically (full-width each).
          Mobile: horizontal scroll-snap carousel (1 card visible).
          Tablet+: vertical stack matching live Swiper slide layout
          (.swiper-slide contains 2 full-width cards stacked).
          Full Swiper with pagination deferred to Phase 4. */}
      <div class="mt-large flex snap-x snap-mandatory gap-large overflow-x-auto pb-small [scrollbar-width:none] [&::-webkit-scrollbar]:hidden md:flex-col md:snap-none md:gap-xlarge md:overflow-visible md:pb-0">
        {slide1.map((t) => (
          <div class="shrink-0 basis-[90%] snap-start md:basis-auto md:shrink md:w-full">
            <article
              class="testimonial-card flex items-start gap-medium border border-white h-full"
            >
              <div class="flex-1">
                <p
                  class="font-heading text-xl md:text-2xl font-light leading-[1.35] text-white"
                >
                  {t.quote}
                </p>
                <div class="mt-medium">
                  <p class="font-body text-sm font-medium text-white">{t.name}</p>
                  <p class="font-body text-sm text-stone-300">{t.role}</p>
                </div>
              </div>
              <img
                src={avatar}
                alt=""
                loading="lazy"
                class="h-24 w-24 shrink-0 rounded-full object-cover md:h-[9.5rem] md:w-[9.5rem]"
              />
            </article>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Mobile (default): radius 96/96/16/16, column layout, smaller padding.
     Matches live .testimonial_card at max-width: 767px. */
  .testimonial-card {
    border-radius: 96px 96px 16px 16px;
    padding: 1.5rem;
    flex-direction: column;
  }
  /* Tablet keeps mobile radius, scales padding */
  @media (min-width: 768px) {
    .testimonial-card {
      padding: 2rem;
    }
  }
  /* Desktop: asymmetric radius, row layout, full padding.
     Matches live .testimonial_card at min-width: 992px. */
  @media (min-width: 992px) {
    .testimonial-card {
      border-radius: 40px 96px 96px 40px;
      padding: 3rem;
      flex-direction: row;
    }
  }
</style>
