---
import Logo from './Logo.astro';
import { contact, social, navLinks, site } from '../../config';
---
<footer class="bg-bg border-t border-white/10 px-small md:px-large py-section-medium">
  <div class="max-w-site-xlarge mx-auto grid gap-large md:grid-cols-3">
    <div>
      <Logo class="h-8 w-auto text-white mb-medium" />
      <p class="font-body text-stone-200">{site.tagline}</p>
    </div>

    <div>
      <h3 class="font-heading text-lg text-white mb-small">Navigate</h3>
      <ul class="flex flex-col gap-xsmall font-body text-stone-200">
        {navLinks.map((link) => (
          <li><a href={link.href} class="hover:text-mint-200">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-heading text-lg text-white mb-small">Contact</h3>
      <ul class="flex flex-col gap-xsmall font-body text-stone-200">
        <li><a href={`mailto:${contact.email}`} class="hover:text-mint-200">{contact.email}</a></li>
        <li><a href={`tel:${contact.phone.replace(/\s+/g, '')}`} class="hover:text-mint-200">{contact.phone}</a></li>
        {social.linkedin && (
          <li><a href={social.linkedin} target="_blank" rel="noopener" class="hover:text-mint-200">LinkedIn</a></li>
        )}
      </ul>
    </div>
  </div>

  <!-- Slot for ContactForm, wired in Phase 2 -->
  <div class="max-w-site-xlarge mx-auto mt-section-medium">
    <slot name="contact-form" />
  </div>

  <p class="max-w-site-xlarge mx-auto mt-section-medium text-center font-body text-sm text-stone-400">
    © {new Date().getFullYear()} {site.name}
  </p>
</footer>
