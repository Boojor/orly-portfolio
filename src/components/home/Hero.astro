---
import HeroSplitText from './HeroSplitText.astro';
import HeroMetrics from './HeroMetrics.astro';
import VerticalLabel from './VerticalLabel.astro';
import ScrollNavSwapper from '../layout/ScrollNavSwapper.astro';

// Headline structure mirrors the live Webflow markup — four decorated
// "figure", "it", "out", "later" words flow inside the larger sentence.
// "I turn" is split into two tokens so per-word animation stays clean.
const headlineWords = [
  'I',
  'turn',
  'figure',
  'it',
  'out',
  'later',
  'into',
  'shipped',
  'product',
];
const highlightIndex = [2, 3, 4, 5];
const marks: (string | null)[] = [
  null,
  null,
  '/assets/hero/mark-figure.svg',
  '/assets/hero/mark-it.svg',
  '/assets/hero/mark-out.svg',
  null,
  null,
  null,
  null,
];

const subcopy =
  "I dig into the business mess, figure out what actually drives value, and design experiences that deliver. Less stakeholder theater, more product in users' hands.";

const metrics = [
  { value: '15+ yrs', label: 'Shaping Products' },
  { value: '170+', label: 'Products & Features Shipped' },
  { value: '93%', label: 'Clients Returning for More' },
];
---
<section class="relative overflow-hidden">
  <ScrollNavSwapper />

  {/* Background image is rendered at body level in BaseLayout.astro
     (matches live .bg-image which is a sibling of main-wrapper).
     No overlay — the source image's dark left side carries the
     headline's text contrast. */}

  <div class="relative mx-auto w-full max-w-site-xxlarge px-small md:px-large pt-[8rem] lg:pt-[9rem] pb-0">
    <div class="grid grid-cols-1 gap-large md:grid-cols-[minmax(0,1fr)_minmax(0,360px)] md:gap-xlarge lg:grid-cols-[minmax(0,1.1fr)_minmax(0,380px)_auto] lg:gap-xlarge items-center">
      {/* Column 1 — headline + sub + CTA */}
      <div class="flex flex-col items-start gap-small">
        <HeroSplitText
          words={headlineWords}
          highlightIndex={highlightIndex}
          marks={marks}
        />

        <p class="max-w-site-medium font-body text-lg md:text-xl text-stone-200 leading-relaxed">
          {subcopy}
        </p>

        <div class="mt-xsmall">
          {/* .button base from live: bg-yellow-500, white text, 16px radius,
              1rem 2.5rem padding, 1.125rem 700 weight */}
          <a
            href="#contact"
            class="inline-flex items-center justify-center rounded-2xl border border-yellow-500 bg-yellow-500 px-[2.5rem] py-[1rem] font-heading text-lg font-bold text-white transition-colors hover:bg-yellow-600 hover:border-yellow-600"
          >
            Book a consult
          </a>
        </div>
      </div>

      {/* Column 2 — portrait. On mobile we let the portrait dominate
          (full container width, matching live where the photo is a hero
          feature). On tablet+ it's constrained so the 3-col layout
          balances. */}
      <div class="relative w-full">
        <img
          src="/assets/hero/portrait.webp"
          alt="Portrait of Orly Boojor"
          loading="eager"
          fetchpriority="high"
          class="mx-auto w-full max-w-[520px] md:max-w-[380px] lg:max-w-[420px] h-auto object-contain"
        />
      </div>

      {/* Column 3 — metrics stack + vertical label. Hidden below lg to
         match the live site where the metrics column drops on tablet. */}
      <div class="hidden lg:flex items-stretch gap-large">
        <HeroMetrics metrics={metrics} />
        <VerticalLabel />
      </div>

      {/* Mobile metrics (shown only on smallest screens, matching the
         live site which drops metrics on tablet via `display: none`). */}
      <div class="md:hidden">
        <HeroMetrics metrics={metrics} />
      </div>
    </div>
  </div>
</section>
