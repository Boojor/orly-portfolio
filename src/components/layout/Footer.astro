---
// Footer — mirrors live Webflow `.footer_component` with a `variant`
// swap for internal (case-study) pages per QA (image12/image13):
//   default (home):
//     - top bg yellow, text dark, decorative footer.svg ornament
//     - form submit button dark bg + white text
//   dark (case study):
//     - top bg dark gray-900, text white, NO ornament
//     - form submit button YELLOW bg + white text
//     - form field text/borders recolored to be readable on dark
//
// Live CSS references (default/light variant):
//   .footer_top-content { background-color: yellow-500; color: black; }
//   .footer_bottom-content { background-color: gray-900; }
//   .footer_svg { position: absolute; inset: -116px 0% auto 196px;
//                 width: 126px; } (desktop)
import ContactForm from '../home/ContactForm.astro';
import { contact, site } from '../../config';

interface Props {
  variant?: 'default' | 'dark';
}

const { variant = 'default' } = Astro.props;
const isDark = variant === 'dark';
const topBg = isDark ? 'bg-bg' : 'bg-yellow-500';
const topText = isDark ? 'text-white' : 'text-bg';
const topHeadingColor = isDark ? 'text-white' : 'text-bg';
const topParaColor = isDark ? 'text-white/80' : 'text-bg/80';
---
<footer id="contact" class="text-white">
  {/* Top section — yellow/light on home, dark on case study pages */}
  <div class:list={[topBg, topText]}>
    <div class="px-small md:px-large py-section-large">
      <div class="mx-auto max-w-site-xlarge">
        <div class="flex flex-col gap-large lg:grid lg:grid-cols-2 lg:gap-xlarge">
          {/* Left: heading + ornament SVG + paragraph. Ornament is hidden
              on case-study pages per QA: "remove the ornament only in
              internal pages". */}
          <div class="flex flex-col">
            <div class="relative">
              <h2
                class:list={[
                  'font-heading text-[2.5rem] md:text-[3.5rem] xl:text-[4.5rem] leading-[1.05] font-black capitalize',
                  topHeadingColor,
                ]}
              >
                Let&rsquo;s work together
              </h2>
              {!isDark && (
                <img
                  src="/assets/footer/footer.svg"
                  alt=""
                  loading="lazy"
                  class="pointer-events-none absolute h-16 w-16 md:h-20 md:w-20 xl:h-[126px] xl:w-[126px] -top-16 right-0 md:-top-24 md:right-4 xl:-top-[116px] xl:left-[196px] xl:right-auto"
                />
              )}
            </div>
            <p class:list={['mt-medium max-w-site-medium font-body text-base md:text-lg leading-relaxed', topParaColor]}>
              I love meeting new people and hearing about interesting problems.
              Drop me a line.
            </p>
          </div>

          {/* Right: form */}
          <div class="w-full">
            <ContactForm variant={variant} />
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Bottom section — dark with white text */}
  <div class="bg-gray-900 px-small md:px-large py-medium">
    <div
      class="mx-auto flex max-w-site-xlarge flex-col gap-small md:flex-row md:items-center md:justify-between"
    >
      <div class="flex flex-wrap items-center gap-small text-white">
        <span class="font-body text-sm">Ways to contact me:</span>
        <a
          href={`tel:${contact.phone.replace(/\s+/g, '')}`}
          class="inline-flex items-center gap-xsmall font-body text-sm hover:text-yellow-500"
        >
          <img
            src="/assets/footer/Mobile-phone.svg"
            alt=""
            width="20"
            height="20"
            loading="lazy"
            class="h-5 w-5"
          />
          <p class="font-body text-sm">{contact.phone}</p>
        </a>
        <span class="h-4 w-px bg-white/30" aria-hidden="true"></span>
        <a
          href={`mailto:${contact.email}`}
          class="inline-flex items-center gap-xsmall font-body text-sm hover:text-yellow-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M1.59375 4.5C1.59375 4.22386 1.81761 4 2.09375 4H17.901C18.1772 4 18.401 4.22386 18.401 4.5V15.5052C18.401 15.7814 18.1772 16.0052 17.901 16.0052H2.09375C1.81761 16.0052 1.59375 15.7813 1.59375 15.5052V4.5Z"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
            <path
              d="M2.19922 6.25098L10.0026 11.2031L17.806 6.25098"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
          {contact.email}
        </a>
      </div>
      <p class="font-body text-xs text-stone-400">
        All rights reserved to {site.name} {new Date().getFullYear()}
      </p>
    </div>
  </div>
</footer>
