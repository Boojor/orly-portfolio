---
// A single tile in the WorkGrid — mirrors `.work_visuals` + `.project-overlay` +
// `.project-hover` from the live Webflow site exactly. Every tile on live uses
// the same generic `Project-thumbnail.webp` regardless of whether the link is
// real or `href="#"`, and every overlay says "DIVE IN".
//
// `duplicateOverlay` ports a Webflow authoring accident on live's first
// `href="#"` tile, which contains the `.project-overlay` block twice in a row
// inside the same `<a>`. Preserved verbatim per the no-invention rule (same
// policy that keeps "Design systems that scales" as-is).
import Button from '../ui/Button.astro';

interface Props {
  href: string;
  thumbnail: string;
  srcset?: string;
  alt: string;
  duplicateOverlay?: boolean;
}

const { href, thumbnail, srcset, alt, duplicateOverlay = false } = Astro.props;
---
{/* Live .work_visuals literal port via `work-tile` class in
    global.css @layer utilities (rules there override Tailwind's
    cascade correctly at the 992px breakpoint — same pattern as the
    hero grid + nav logo). Base + media query rules:
      Mobile (≤767px):  aspect-square, max-w 44rem, mx-auto
      Tablet (768-991): aspect-square, max-w 25rem, min-h 19.25rem
      Desktop (992+):   aspect auto, no max-w, min-h 30rem */}
<a
  href={href}
  class="work-tile group relative block w-full overflow-hidden rounded-2xl"
>
  <img
    src={thumbnail}
    srcset={srcset}
    sizes="(min-width: 1024px) 40vw, (min-width: 768px) 45vw, 90vw"
    alt={alt}
    loading="lazy"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div
    class="absolute inset-0 flex items-center justify-center bg-bg/70 opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
  >
    <Button variant="outline-pill" as="div">DIVE IN</Button>
  </div>
  {duplicateOverlay && (
    <div
      class="absolute inset-0 flex items-center justify-center bg-bg/70 opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
    >
      <Button variant="outline-pill" as="div">DIVE IN</Button>
    </div>
  )}
</a>
