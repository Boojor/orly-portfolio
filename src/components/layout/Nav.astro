---
import NavInner from './NavInner.astro';

interface Props {
  /**
   * Match live Webflow's two variants (per CLAUDE.md "match live literally"):
   *   'dark' (default, home) — absolute nav transparent over dark hero with
   *      WHITE text; fixed nav dark bg + white text (home's `.navbar_fixed`).
   *   'light' (case-study pages) — absolute nav transparent with BLACK text
   *      (live `.navbar_absolute { color: var(--color-scheme-1--text) }`
   *      where scheme-1-text is dark on white-body pages); fixed nav gets
   *      `.white` modifier = white bg + black text.
   *   Hamburger bars flip colors to match the text color.
   */
  variant?: 'dark' | 'light';
}
const { variant = 'dark' } = Astro.props;
const isLight = variant === 'light';
// Shared across both absolute + fixed navs — live uses the same text color
// for both on a given page variant.
const navText = isLight ? 'text-black' : 'text-white';
const barsColor = isLight ? 'bg-black' : 'bg-white';
const dividerColor = isLight ? 'bg-black/40' : 'bg-white/40';
const fixedNavBg = isLight ? 'bg-white' : 'bg-bg';
---
{/* Absolute variant: transparent, overlaid on hero. Literal port of
    live: outer padding 0 5%, inner max-w-[97.5rem] mx-auto so nav
    content caps at 1560px at wide viewports — matching hero and
    sections. Logo sizing via `.nav-logo-absolute` in global.css. */}
<nav
  data-nav="absolute"
  class="absolute top-0 left-0 right-0 z-40 px-[5%] py-[1rem]"
>
  <NavInner
    navText={navText}
    barsColor={barsColor}
    dividerColor={dividerColor}
    logoClass="nav-logo-absolute"
  />
</nav>

{/* Fixed variant — literal port of live .navbar_fixed:
    background-color: var(--bg-color) (solid #171717, NO blur, NO border),
    padding: 0.5rem 5%. Transition: fade + slide in from top.
    nav-scroll-swap.ts toggles `nav-fixed--shown` class instead of
    `hidden` so the transition can animate. Light variant:
    `.navbar_fixed.white` flips bg to white + text to black.
    Logo sizing via `.nav-logo-sticky` in global.css. */}
<nav
  data-nav="fixed"
  class={`nav-fixed fixed top-0 left-0 right-0 z-50 ${fixedNavBg} px-[5%] py-[0.5rem]`}
>
  <NavInner
    navText={navText}
    barsColor={barsColor}
    dividerColor={dividerColor}
    logoClass="nav-logo-sticky"
  />
</nav>
