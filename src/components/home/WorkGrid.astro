---
// "My Work" section — mirrors live Webflow exactly:
//
// Mobile (< md): text block first, then horizontal scroll-snap carousel
//   of 5 tiles (matches live Swiper showing 1 tile with peek of next).
//
// Desktop (md+): 6-cell grid
//   [cinch tile]         [text block]
//   [fbx-checkout tile]  [placeholder tile href="#"]
//   [placeholder tile]   [fbx-partnerships tile]
//
// All tiles on live use the same generic `Project-thumbnail.webp` and
// the same "DIVE IN" hover overlay — real links and placeholder links
// alike.
import WorkTile from './WorkTile.astro';
import Button from '../ui/Button.astro';
import Heading from '../ui/Heading.astro';
import SectionWrapper from '../ui/SectionWrapper.astro';

const thumbnail = '/assets/work/Project-thumbnail.webp';
const srcset =
  '/assets/work/Project-thumbnail-p-500.webp 500w, /assets/work/Project-thumbnail.webp 624w';

// Tiles in desktop grid order — row-major, left-to-right, top-to-bottom.
const tiles = [
  { href: '/work/cinch-logistics', alt: 'Cinch Logistics case study' },
  { href: '/work/fundbox-pay-checkout', alt: 'Fundbox Pay Checkout case study' },
  { href: '#', alt: '' },
  { href: '#', alt: '' },
  { href: '/work/fundbox-partnerships', alt: 'Fundbox Partnerships case study' },
];
---
{/* Live: .padding-global { padding: 0 5% } + .container-large
    { max-width: 97.5rem } + .padding-section-large { padding: 4rem 0 }.
    Single .work_layout grid with 6 items (5 tiles + 1 text-contents
    wrapper at position 2) that reflows across breakpoints:
      Mobile (≤767px): flex column, all stacked, tiles aspect-square max-w 44rem
      Tablet (768-991): 2-col grid, tiles aspect-square max-w 25rem
      Desktop (992+):   2-col grid, tiles min-h 30rem (non-square) */}
<SectionWrapper id="my-work">
  <div data-work-layout class="grid grid-cols-1 md:grid-cols-2 gap-x-[2rem] gap-y-[1.5rem] md:gap-y-[4rem] min-[992px]:gap-y-[3rem]">
      {/* 1. Cinch tile */}
      <WorkTile
        href={tiles[0].href}
        thumbnail={thumbnail}
        srcset={srcset}
        alt={tiles[0].alt}
      />

      {/* 2. Text block — grid position 2 at tablet+. At mobile
          (≤767px) live uses `order: -9999` to float it to the TOP
          of the stack (before all tiles). Ported via `order-first
          md:order-none`. */}
      <div class="order-first md:order-none flex items-center justify-between gap-medium md:gap-large">
        {/* Vertical label — literal port of live `.vertical-label`:
            z-index: 1, gap: 1rem, flex-col, justify-center,
            align-self: stretch, align-items: center, width: 1.5rem,
            overflow: visible. Live markup order: <p> first, then a
            single <div class="line"> below (flex:1 so it fills the
            remaining vertical space). Solid white, no opacity. */}
        <div class="flex flex-col items-center justify-center self-stretch gap-[1rem] w-[1.5rem] shrink-0 overflow-visible">
          <p
            class="font-body text-xs text-white uppercase tracking-widest [writing-mode:vertical-rl] whitespace-nowrap"
          >
            The Designer Effect
          </p>
          <div class="w-px flex-1 bg-white" aria-hidden="true"></div>
        </div>

        <div class="flex flex-col items-start">
          <Heading as="h2" size="section" leading="tight" weight="black">
            Examples of My Work
          </Heading>
          <p class="mt-medium max-w-site-medium font-body text-base md:text-lg text-stone-200 leading-relaxed">
            Working across industries keeps my thinking fresh and my skills
            sharp. But I&rsquo;m especially drawn to complex B2B products where
            the layers, decisions, and details turn the work into something
            deeply rewarding.
          </p>
          <Button variant="primary" href="#" class="mt-medium">See all work</Button>
        </div>
      </div>

      {/* 3. Fundbox Pay Checkout tile */}
      <WorkTile
        href={tiles[1].href}
        thumbnail={thumbnail}
        srcset={srcset}
        alt={tiles[1].alt}
      />

      {/* 4. Placeholder tile — live's first `href="#"` tile has the
          `.project-overlay` block duplicated inside the `<a>` (Webflow
          authoring accident). Ported verbatim via `duplicateOverlay`. */}
      <WorkTile
        href={tiles[2].href}
        thumbnail={thumbnail}
        srcset={srcset}
        alt={tiles[2].alt}
        duplicateOverlay
      />

      {/* 5. Placeholder tile */}
      <WorkTile
        href={tiles[3].href}
        thumbnail={thumbnail}
        srcset={srcset}
        alt={tiles[3].alt}
      />

      {/* 6. Fundbox Partnerships tile */}
      <WorkTile
        href={tiles[4].href}
        thumbnail={thumbnail}
        srcset={srcset}
        alt={tiles[4].alt}
      />
    </div>
</SectionWrapper>
