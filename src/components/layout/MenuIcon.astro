---
interface Props {
  open?: boolean;
}
const { open = false } = Astro.props;
---
<div class:list={['menu-icon', { 'is-open': open }]} aria-hidden="true">
  <span></span>
  <span></span>
  <span></span>
</div>

<style>
  .menu-icon {
    display: inline-block;
    width: 24px;
    height: 18px;
    position: relative;
  }
  .menu-icon span {
    display: block;
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: currentColor;
    transition: transform 0.3s ease, opacity 0.3s ease, top 0.3s ease;
  }
  .menu-icon span:nth-child(1) { top: 0; }
  .menu-icon span:nth-child(2) { top: 8px; }
  .menu-icon span:nth-child(3) { top: 16px; }

  .menu-icon.is-open span:nth-child(1) { top: 8px; transform: rotate(45deg); }
  .menu-icon.is-open span:nth-child(2) { opacity: 0; }
  .menu-icon.is-open span:nth-child(3) { top: 8px; transform: rotate(-45deg); }
</style>
