---
// A single tile in the WorkGrid — mirrors `.work_visuals` + `.project-overlay` +
// `.project-hover` from the live Webflow site exactly. Every tile on live uses
// the same generic `Project-thumbnail.webp` regardless of whether the link is
// real or `href="#"`, and every overlay says "DIVE IN".
interface Props {
  href: string;
  thumbnail: string;
  srcset?: string;
  alt: string;
}

const { href, thumbnail, srcset, alt } = Astro.props;
---
<a
  href={href}
  class="group relative block w-full overflow-hidden rounded-2xl bg-stone-900 min-h-[15rem] md:min-h-[19.25rem] md:aspect-square md:max-w-[25rem] md:self-center lg:min-h-[30rem] lg:aspect-auto lg:max-w-none"
>
  <img
    src={thumbnail}
    srcset={srcset}
    sizes="(min-width: 1024px) 40vw, (min-width: 768px) 45vw, 90vw"
    alt={alt}
    loading="lazy"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div
    class="absolute inset-0 flex items-center justify-center bg-bg/70 opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
  >
    <div
      class="rounded-full border border-white px-xlarge py-small font-heading text-xl text-white md:text-2xl"
    >
      DIVE IN
    </div>
  </div>
</a>
