---
// Hero metric callouts. Copy comes from the parent `Hero.astro` so the
// values stay editable in one place. The layout is a vertical stack so it
// can live inside the hero's right-hand column (desktop) or stretch across
// a row on narrower breakpoints.
interface Metric {
  value: string;
  label: string;
}
interface Props {
  metrics: Metric[];
}
const { metrics } = Astro.props;
---
{/* Literal port of live .hero_metrics:
      flex-col, justify-center (vertical center), items-end (right-align),
      w-full, h-full, gap 3.5rem.
    Each .hero_metric: flex-col, items-end (right-align text), justify-center.
    .h_hero_metrics font-size: 3rem (48px) at desktop. */}
<div data-hero-metrics-stack class="flex flex-col justify-center items-end w-full h-full gap-[3.5rem]">
  {
    metrics.map((m) => (
      <div class="flex flex-col items-end justify-center border-t border-white/15 pt-small w-full text-right">
        <span class="font-heading text-[3rem] text-white leading-none">
          {m.value}
        </span>
        <span class="mt-xxsmall font-body text-sm text-stone-200">
          {m.label}
        </span>
      </div>
    ))
  }
</div>
