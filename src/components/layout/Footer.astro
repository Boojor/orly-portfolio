---
// Footer — mirrors live Webflow `.footer_component` exactly.
// Two-tone:
//   1. footer_top-content:  YELLOW-500 bg + BLACK text. H2 "Let's work together"
//      with decorative SVG floating above it, paragraph, and contact form.
//   2. footer_bottom-content: GRAY-900 bg + WHITE text. Phone + email inline
//      with icons + copyright line.
//
// Live CSS references:
//   .footer_top-content { background-color: yellow-500; color: black; }
//   .footer_bottom-content { background-color: gray-900; }
//   .footer_svg { position: absolute; inset: -116px 0% auto 196px;
//                 width: 126px; } (desktop)
import ContactForm from '../home/ContactForm.astro';
import { contact, site } from '../../config';
---
<footer id="contact" class="text-white">
  {/* Top section — yellow with black text */}
  <div class="bg-yellow-500 text-bg">
    <div class="px-small md:px-large py-section-large">
      <div class="mx-auto max-w-site-xlarge">
        <div class="flex flex-col gap-large lg:grid lg:grid-cols-2 lg:gap-xlarge">
          {/* Left: heading + svg + paragraph */}
          <div class="flex flex-col">
            {/* Wrapper is relative so the decorative SVG can float above the heading */}
            <div class="relative">
              <h2
                class="font-heading text-[2.5rem] md:text-[3.5rem] xl:text-[4.5rem] leading-[1.05] font-black capitalize text-bg"
              >
                Let&rsquo;s work together
              </h2>
              <img
                src="/assets/footer/footer.svg"
                alt=""
                loading="lazy"
                class="pointer-events-none absolute h-16 w-16 md:h-20 md:w-20 xl:h-[126px] xl:w-[126px] -top-16 right-0 md:-top-24 md:right-4 xl:-top-[116px] xl:left-[196px] xl:right-auto"
              />
            </div>
            <p class="mt-medium max-w-site-medium font-body text-base md:text-lg text-bg/80 leading-relaxed">
              I love meeting new people and hearing about interesting problems.
              Drop me a line.
            </p>
          </div>

          {/* Right: form */}
          <div class="w-full">
            <ContactForm />
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Bottom section — dark with white text */}
  <div class="bg-gray-900 px-small md:px-large py-medium">
    <div
      class="mx-auto flex max-w-site-xlarge flex-col gap-small md:flex-row md:items-center md:justify-between"
    >
      <div class="flex flex-wrap items-center gap-small text-white">
        <span class="font-body text-sm">Ways to contact me:</span>
        <a
          href={`tel:${contact.phone.replace(/\s+/g, '')}`}
          class="inline-flex items-center gap-xsmall font-body text-sm hover:text-yellow-500"
        >
          <img
            src="/assets/footer/Mobile-phone.svg"
            alt=""
            width="20"
            height="20"
            loading="lazy"
            class="h-5 w-5"
          />
          {contact.phone}
        </a>
        <span class="h-4 w-px bg-white/30" aria-hidden="true"></span>
        <a
          href={`mailto:${contact.email}`}
          class="inline-flex items-center gap-xsmall font-body text-sm hover:text-yellow-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M1.59375 4.5C1.59375 4.22386 1.81761 4 2.09375 4H17.901C18.1772 4 18.401 4.22386 18.401 4.5V15.5052C18.401 15.7814 18.1772 16.0052 17.901 16.0052H2.09375C1.81761 16.0052 1.59375 15.7813 1.59375 15.5052V4.5Z"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
            <path
              d="M2.19922 6.25098L10.0026 11.2031L17.806 6.25098"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
          {contact.email}
        </a>
      </div>
      <p class="font-body text-xs text-stone-400">
        All rights reserved to {site.name} {new Date().getFullYear()}
      </p>
    </div>
  </div>
</footer>
