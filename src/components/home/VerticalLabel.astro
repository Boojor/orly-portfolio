---
// Vertical decorative label used inside the hero's metrics column.
// Mirrors `.vertical-label--hero` from the live Webflow site: heart icon,
// thin vertical line, then rotated uppercase text. Hidden below md to
// match the live site (which drops the entire metrics column on tablet).
---
{/* Literal port of live .vertical-label--hero:
    align-self: stretch, flex-col, justify-center, items-center,
    w-[1.5rem], opacity: 0.2, gap: 1rem.
    Children: heart icon at top, .line (flex:1, 1px wide) fills
    remaining vertical space, rotated text at bottom. Because the
    parent col has height=100% of hero, the line stretches to fill
    all available space between icon and text. */}
<div class="hidden md:flex flex-col items-center justify-center self-stretch gap-[1rem] w-[1.5rem] opacity-20">
  <svg
    class="h-4 w-4 text-yellow-500 shrink-0"
    viewBox="0 0 16 16"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      d="M15 4.78393C15 2.69412 13.3125 1 11.2308 1C8.81263 1 8.30986 2.73222 8 3.48201C7.69012 2.73222 7.18737 1 4.76923 1C2.68754 1 1 2.69412 1 4.78393C1 8.88834 5.71823 12.964 8 15C10.2818 12.964 15 8.88834 15 4.78393Z"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linejoin="round"
    />
  </svg>
  <div class="w-px flex-1 bg-white self-stretch mx-auto"></div>
  <p
    class="font-body text-xs text-stone-200 uppercase tracking-widest [writing-mode:vertical-rl] rotate-180 whitespace-nowrap shrink-0"
  >
    I don&rsquo;t need my hand held - I hold yours.
  </p>
</div>
