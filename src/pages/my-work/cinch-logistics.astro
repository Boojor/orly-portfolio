{/* Jump-to dropdown — hover-to-open, hover-out to close (per QA).
    Hover fires on the whole wrapper so moving from the trigger pill
    down into the menu pane keeps it open. Touch devices get a click
    fallback since hover isn't reliable there. */}
<script>
  const dropdowns = document.querySelectorAll<HTMLElement>('.work_dropdown');
  dropdowns.forEach((wrap) => {
    const pane = wrap.querySelector<HTMLElement>('.dropdown-text');
    const trigger = wrap.querySelector<HTMLElement>('.dropdown');
    if (!pane || !trigger) return;

    // Desktop: hover open/close on the wrapper so the pane stays
    // reachable from the trigger.
    wrap.addEventListener('mouseenter', () => wrap.classList.add('is-open'));
    wrap.addEventListener('mouseleave', () => wrap.classList.remove('is-open'));

    // Touch fallback: tap trigger to open; tap elsewhere to close.
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      wrap.classList.toggle('is-open');
    });

    // Tapping a link inside the pane closes (navigation will follow).
    pane.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => wrap.classList.remove('is-open'));
    });
  });
</script>
