---
// Hero metric callouts. Copy comes from the parent `Hero.astro` so the
// values stay editable in one place. The layout is a vertical stack so it
// can live inside the hero's right-hand column (desktop) or stretch across
// a row on narrower breakpoints.
interface Metric {
  value: string;
  label: string;
}
interface Props {
  metrics: Metric[];
}
const { metrics } = Astro.props;
---
<div data-hero-metrics-stack class="flex flex-col gap-large">
  {
    metrics.map((m) => (
      <div class="flex flex-col border-t border-white/15 pt-small">
        <span class="font-heading text-4xl md:text-5xl text-white leading-none">
          {m.value}
        </span>
        <span class="mt-xxsmall font-body text-sm text-stone-200">
          {m.label}
        </span>
      </div>
    ))
  }
</div>
