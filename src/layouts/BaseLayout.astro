---
import '../styles/global.css';
import { site } from '../config';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Orly Boojor — Product Designer. Portfolio of product design work across fintech and logistics.',
  ogImage = '/assets/og-default.jpg',
} = Astro.props;

const fullTitle = title === site.name ? title : `${title} — ${site.name}`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/webclip.png" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Adobe Typekit -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="preconnect" href="https://p.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/nod3oqm.css" />

    <title>{fullTitle}</title>
  </head>
  <body>
    <slot name="nav" />
    {/* Global hero background image — matches live Webflow .bg-image:
        sibling of main, absolutely positioned from the top, fixed
        min-height: 1270px, extends beyond the hero section into the
        content area below. No darkening overlay — the source image
        is designed with dark zones for text contrast. */}
    <img
      src="/assets/hero/hero-bg.webp"
      srcset="/assets/hero/hero-bg-p-500.webp 500w, /assets/hero/hero-bg-p-800.webp 800w, /assets/hero/hero-bg-p-1080.webp 1080w, /assets/hero/hero-bg-p-1600.webp 1600w, /assets/hero/hero-bg-p-2000.webp 2000w, /assets/hero/hero-bg-p-2600.webp 2600w, /assets/hero/hero-bg-p-3200.webp 3200w"
      sizes="100vw"
      alt=""
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
      class="pointer-events-none absolute top-0 left-0 right-0 z-[-1] min-h-[1270px] w-full object-cover object-top"
    />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
