---
// Testimonials section — mirrors `.work_testimonials_section` on live Webflow.
// Live uses a Swiper slider (2 slides × 2 cards); we render slide 1 statically
// (2 cards) with non-functional prev/next arrows for visual parity. Swiper
// animation is deferred to Phase 4.
//
// Quotes, names, roles, and avatars are copied LITERALLY from the live site —
// including the CMS-flattened duplicate wording and the fact that all four
// cards use the same person and same Avatar-898.svg placeholder.

interface Testimonial {
  quote: string;
  name: string;
  role: string;
}

const slide1: Testimonial[] = [
  {
    quote:
      '“Hiring Orly was one of our best product decisions. She has a unique talent for translating high-level business goals into a user experience that just works.“Hiring Orly was one of our best product decisions. She has a unique talent for translating high-level business goals into a user.”',
    name: 'Sarah Jenkins',
    role: 'CEO, Kestrel',
  },
  {
    quote:
      '“Hiring Orly was one of our best product decisions. She has a unique talent for translating high-level business goals into a userthat just.”',
    name: 'Sarah Jenkins',
    role: 'CEO, Kestrel',
  },
];

const avatar = '/assets/testimonials/Avatar-898.svg';
const bgSrc = '/assets/testimonials/footer-image.webp';
const bgSrcset = [
  '/assets/testimonials/footer-image-p-500.webp 500w',
  '/assets/testimonials/footer-image-p-800.webp 800w',
  '/assets/testimonials/footer-image-p-1080.webp 1080w',
  '/assets/testimonials/footer-image-p-1600.webp 1600w',
  '/assets/testimonials/footer-image-p-2000.webp 2000w',
  '/assets/testimonials/footer-image.webp 4312w',
].join(', ');
---
<section id="testimonials" class="relative isolate overflow-hidden">
  {/* Full-bleed background image — live uses min-height:1400px so the
      image dominates the section. We let it fill + apply a gentle dark
      gradient for text legibility without hiding the image. */}
  <img
    src={bgSrc}
    srcset={bgSrcset}
    sizes="100vw"
    alt=""
    loading="lazy"
    class="absolute inset-0 z-0 h-full w-full object-cover"
  />
  <div
    class="absolute inset-0 z-[1] bg-gradient-to-b from-bg/70 via-bg/40 to-bg/70"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 px-[5%] py-section-large">
    <div class="mx-auto max-w-[97.5rem]">
      {/* Header: label + heading + arrows (arrows deferred to Phase 4) */}
      <div class="flex flex-col gap-medium">
        {/* Label row */}
        <div class="flex items-center gap-small">
          <p class="font-body text-xs uppercase tracking-widest text-stone-200">
            Testimonials
          </p>
          <div class="h-px flex-1 bg-white/30" aria-hidden="true"></div>
        </div>

        {/* Heading + arrows */}
        <div class="flex flex-col gap-medium md:flex-row md:items-end md:justify-between md:gap-large">
          <h2
            class="font-heading text-[2.25rem] md:text-[2.75rem] xl:text-[3.5rem] leading-[1.15] font-black text-white max-w-site-large"
          >
            What my team has to say
          </h2>

          {/* Prev/Next buttons — visual parity only (non-functional;
              swiper deferred to Phase 4).
              Live .slider-button:
                border: 1px solid transparent
                background-color: #0000001a (black 10%)
                color: white
                border-radius: 999px
                padding: 1rem 2.5rem
                display: flex; justify-content: center; align-items: center
              Live .team-slider_btn_layout: gap 0.5rem, flex-wrap */}
          <div class="flex gap-[0.5rem]" aria-hidden="true">
            <a
              class="inline-flex items-center justify-center rounded-full border border-transparent bg-[#0000001a] px-[2.5rem] py-[1rem] text-white opacity-50"
            >
              <div class="flex h-4 w-4 items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 16 16" fill="none" class="rotate-180">
                  <path d="M0.8125 8H15.1875" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                  <path d="M8.47949 14.7087L15.1878 8.00033L8.47949 1.29199" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </div>
            </a>
            <a
              class="inline-flex items-center justify-center rounded-full border border-transparent bg-[#0000001a] px-[2.5rem] py-[1rem] text-white"
            >
              <div class="flex h-4 w-4 items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 16 16" fill="none">
                  <path d="M0.8125 8H15.1875" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                  <path d="M8.47949 14.7087L15.1878 8.00033L8.47949 1.29199" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </div>
            </a>
          </div>
        </div>
      </div>

      {/* Cards container.
          Mobile (<768): horizontal scroll-snap carousel, one card
          visible, swipe to navigate (matches live's Swiper behavior).
          md+: vertical stack (matches live's .swiper-slide containing
          2 full-width cards stacked). */}
      <div class="testimonial-cards mt-large flex snap-x snap-mandatory gap-large overflow-x-auto pb-small [scrollbar-width:none] [&::-webkit-scrollbar]:hidden md:flex-col md:snap-none md:gap-[2rem] md:overflow-visible md:pb-0">
        {slide1.map((t) => (
          <div class="shrink-0 basis-[90%] snap-start md:basis-auto md:shrink md:w-full">
          {/* Literal port of live .testimonial_card:
              Desktop 992+: flex-row, gap 4rem, padding 3rem, asymmetric
                border-radius 40/96/96/40.
              Tablet 768-991 + Mobile <767: flex-col, gap 1.5rem,
                padding (2rem/1.5rem), radius 96/96/16/16.
              Styling lives in the .testimonial-card class below. */}
          <article class="testimonial-card border border-white h-full">
            {/* .testimonial_text — quote + author. */}
            <div class="flex-1 flex flex-col gap-[1.5rem]">
              {/* Live .heading-style-h4.text-weight-light:
                    desktop ≥992: 2rem, lh 1.2
                    tablet 768-991: 1.75rem, lh 1.2 (inherited)
                    mobile ≤767: 1.5rem, lh 1.4
                  font-size rules live in global.css @layer utilities
                  (`.testimonial-quote`) because Tailwind 4's cascade
                  puts arbitrary variants before default ones —
                  `min-[992px]:text-[2rem]` would lose to
                  `md:text-[1.75rem]` at 1440 without this. */}
              <p class="testimonial-quote font-heading font-light text-white">
                {t.quote}
              </p>
              {/* Live .testimonial_author: flex row, gap 0.375rem.
                  Name + role on the same line (wraps on narrow). */}
              <div class="flex flex-row flex-wrap items-baseline gap-x-[0.375rem] gap-y-[0.25rem]">
                <p class="font-body text-[0.875rem] font-medium text-white">{t.name}</p>
                <p class="font-body text-[0.875rem] text-stone-300">{t.role}</p>
              </div>
            </div>
            {/* Live .testimonial-media: 9.5rem × 9.5rem circle, flex-none */}
            <img
              src={avatar}
              alt=""
              loading="lazy"
              class="shrink-0 rounded-full object-cover w-[6rem] h-[6rem] md:w-[9.5rem] md:h-[9.5rem]"
            />
          </article>
          </div>
        ))}
      </div>

      {/* Pagination dots — only visible at mobile where the carousel
          shows 1 card at a time (Phase 4 will wire Swiper). At md+
          both cards are stacked and fully visible so dots are
          redundant. Matches live .team-slider_bullet_item styling. */}
      <div class="mt-medium flex items-center gap-[0.5rem] md:hidden" aria-hidden="true">
        {[0, 1].map((i) => (
          <span
            class:list={[
              'inline-block aspect-square rounded-full border border-current w-4',
              i === 0 ? 'bg-current' : 'bg-transparent',
            ]}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Literal port of live .testimonial_card.
     Base (mobile ≤767): flex column, padding 1.5rem, gap 1.5rem,
     radius 96/96/16/16, items-start.
     Tablet (768-991): padding 2rem, radius stays 96/96/16/16 (live
     keeps mobile radius on tablet), layout stays column.
     Desktop (≥992): padding 3rem, gap 4rem, radius 40/96/96/40,
     layout flex-row, items-center, justify-between. */
  .testimonial-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: 96px 96px 16px 16px;
  }
  @media (min-width: 768px) {
    .testimonial-card {
      padding: 2rem;
    }
  }
  @media (min-width: 992px) {
    .testimonial-card {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
      padding: 3rem;
      border-radius: 40px 96px 96px 40px;
    }
  }
</style>
